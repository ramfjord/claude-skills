#!/usr/bin/env -S expect -f
# run-swank.expect — bootstrap one SBCL image with swank listening.
#
#   args: WORKTREE_PATH SYSTEM_NAME PORT
#
# Spawns sbcl directly (no tmux), drives it through:
#   1. add WORKTREE_PATH to asdf:*central-registry*
#   2. (ql:quickload :swank)
#   3. (asdf:load-system :SYSTEM_NAME)
#   4. (swank:create-server :port PORT :dont-close t)
# then `interact`s — handing the pty to whoever invoked us (a tmux
# pane, a real terminal) so SBCL keeps running.
#
# Why expect: each load step takes an unknown amount of time. expect
# blocks on the pty in the kernel until SBCL's "* " prompt comes back,
# so we send the next form the moment the previous one completes —
# event-driven, no sleeps, no polling.

if {[llength $argv] < 3} {
    puts stderr "usage: run-swank.expect WORKTREE_PATH SYSTEM PORT \[ASD_DIR ...\]"
    exit 2
}

set path        [lindex $argv 0]
set system      [lindex $argv 1]
set port        [lindex $argv 2]
# Extra ASD-containing dirs to push onto asdf:*central-registry*. The
# bootstrap discovers these (any *.asd in the worktree) and passes
# them so vendored deps resolve. Includes the worktree itself when
# the worktree has its own .asd, so we don't push WORKTREE separately.
set asd_dirs    [lrange $argv 3 end]

# SBCL's top-level prompt: "* " on its own line.
set prompt "\n* "

proc await_prompt {what} {
    global prompt
    expect {
        -ex $prompt {}
        timeout { puts stderr "timeout waiting for prompt after: $what"; exit 3 }
        eof     { puts stderr "unexpected eof after: $what";              exit 4 }
    }
}

set timeout 30
cd $path
spawn sbcl --noinform
# `--noinform` means the very first byte is "* " with no leading
# newline, so our `\n* ` pattern can't match it. Send an empty line to
# produce a fresh prompt that does have the newline.
send -- "\r"
await_prompt "sbcl banner"

# qlot: if the worktree has `.qlot/setup.lisp`, load it before anything
# else. That swaps in qlot's project-local quicklisp and source-registry,
# so `(asdf:load-system :foo)` resolves dependencies through
# `.qlot/dists/` instead of the user's `~/quicklisp/`. Without this,
# qlot-managed deps look "missing" even though they're installed —
# because they're installed under qlot, not under user-quicklisp.
if {[file exists "$path/.qlot/setup.lisp"]} {
    set timeout 60
    send -- "(load \"$path/.qlot/setup.lisp\")\r"
    await_prompt "load .qlot/setup.lisp"
    set timeout 30
}

if {[llength $asd_dirs] > 0} {
    foreach d $asd_dirs {
        send -- "(push (truename \"$d/\") asdf:*central-registry*)\r"
        await_prompt "push central-registry $d"
    }
} else {
    # No asd dirs reported (older callers); fall back to just the worktree.
    send -- "(push (truename \"$path/\") asdf:*central-registry*)\r"
    await_prompt "push central-registry"
}

# Cold Quicklisp + multi-file ASDF loads can take a while.
set timeout 180
send -- "(ql:quickload :swank)\r"
await_prompt "ql:quickload :swank"

send -- "(asdf:load-system :$system)\r"
await_prompt "asdf:load-system :$system"

set timeout 30
# If VLIME_LISP_DIR + VLIME_PORT are set, hand off server startup to
# vlime:main, which boots both swank (on $port) and vlime's JSON listener
# (on $env(VLIME_PORT)) inside the same image. Editor connects to the
# vlime port; eval_swank/lisp-mcp connects to the swank port. One image,
# two protocols, shared state. Otherwise: plain swank only.
if {[info exists env(VLIME_LISP_DIR)] && [info exists env(VLIME_PORT)] \
        && [file exists "$env(VLIME_LISP_DIR)/load-vlime.lisp"]} {
    send -- "(load \"$env(VLIME_LISP_DIR)/load-vlime.lisp\")\r"
    await_prompt "load vlime"
    send -- "(vlime:main :port $env(VLIME_PORT) :swank-port $port :backend :vlime-usocket)\r"
    await_prompt "vlime:main"
} else {
    send -- "(swank:create-server :port $port :dont-close t)\r"
    await_prompt "swank:create-server"
}

# Load the helpers tools.lisp ships (eval-form-at, reload-form). Path
# comes from the TOOLS_LISP env var the bootstrap sets — kept out of
# argv so the trailing variadic ASD_DIRS stay clean.
if {[info exists env(TOOLS_LISP)] && [file exists $env(TOOLS_LISP)]} {
    send -- "(load \"$env(TOOLS_LISP)\")\r"
    await_prompt "load tools.lisp"
}

# Hand the pty to the caller. Blocks until sbcl exits — that's how
# tmux's pane keeps a live REPL after this script's "bootstrap phase"
# is done.
interact
